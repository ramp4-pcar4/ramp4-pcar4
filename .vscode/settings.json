        "src/fixtures/grid/lang",
        "src/fixtures/help/lang",
        "src/fixtures/layer-reorder/lang",
        "src/fixtures/legend/lang",
        "src/fixtures/mapnav/lang",
        "src/fixtures/metadata/lang",
        "src/fixtures/overviewmap/lang",
